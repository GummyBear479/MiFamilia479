# La Familia 479 - Environment Variables
# =====================================
# Copy this file to .env.local and populate with your actual API keys
# NOTE: Never commit .env.local to git - it contains sensitive credentials

# Google Gemini API Key
# Get your key from: https://makersuite.google.com/app/apikey
# Used for: Text generation, Chat, Document analysis, Legal text decoding
VITE_GEMINI_API_KEY=

# Google Imagen API Key
# Get your key from: https://makersuite.google.com/app/apikey
# Used for: Image generation and vision tasks
VITE_IMAGEN_API_KEY=

# Application Mode
# Set to 'development' or 'production' (auto-detected by Vite, but can override)
VITE_APP_MODE=development

# Enable Debug Mode (logs additional information)
# Set to 'true' or 'false'
VITE_DEBUG_MODE=false
